# macOS metadata (AppleDouble sidecars on non-HFS volumes, Finder dir state)
._*
.DS_Store

# Generated by Cargo
# will have compiled files and executables
**/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock - Now committed since jagua-sqs-processor is a binary

# These are backup files generated by rustfmt
**/*.rs.bk

# Covers JetBrains IDEs: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio, WebStorm and Rider
**/.idea/

# VSCode
**/.vscode/

/assets/#*.dxf

/solutions/

# Test output files (generated by integration tests)
**/test_output/

# Prod-tests batch harness: the per-case input fixtures (data.json + input SVG) are committed, but
# everything the harness *generates* on each run is noise — regenerated from those fixtures.
jagua-sqs-processor/tests/testdata/prod-tests/.svg_cache/
jagua-sqs-processor/tests/testdata/prod-tests/*/out/
jagua-sqs-processor/tests/testdata/prod-tests/REPORT.md
jagua-sqs-processor/tests/testdata/prod-tests/REPORT.csv

/act/

input/
*.log
*.pid
*.env
# Sourced from cutl-schemas at build time (scripts/sync-schema.sh), not vendored.
jagua-sqs-processor/asyncapi/jagua-rs.yaml
